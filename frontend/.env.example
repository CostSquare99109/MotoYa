# ═══════════════════════════════════════════
# MotoYa Frontend — Variables de Entorno
# Copiar a .env y configurar los valores reales
# ═══════════════════════════════════════════

# URL base del backend API (OBLIGATORIO en producción)
# Desarrollo:  http://127.0.0.1:8000
# Producción:  https://api.motoya.co
VITE_API_URL=http://127.0.0.1:8000

# URL base del WebSocket (opcional — se deriva de VITE_API_URL si no se establece)
# Desarrollo:  ws://localhost:8000
# Producción:  wss://api.motoya.co
# VITE_WS_URL=ws://localhost:8000
