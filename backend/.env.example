# ─────────────────────────────────────────────────────────────
# MotoYa — Variables de entorno
# Copia este archivo como ".env" y rellena los valores reales.
# NUNCA subas el archivo ".env" al repositorio.
# ─────────────────────────────────────────────────────────────

# ── Base de datos ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://motoya_user:CAMBIA_ESTE_PASSWORD@localhost:5432/motoya

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Archivos ───────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/webp,application/pdf
