# ─────────────────────────────────────────────────────────────
# MotoYa — Variables de entorno
# Copia este archivo como ".env" y rellena los valores reales.
# NUNCA subas el archivo ".env" al repositorio.
# ─────────────────────────────────────────────────────────────

# ── Entorno ────────────────────────────────────────────────────
# development | staging | production
# En production/staging, JWT_SECRET debe ser cambiado del default
# y DATABASE_URL no puede apuntar a localhost.
APP_ENV=development

# ── Base de datos ──────────────────────────────────────────────
# PostgreSQL con PostGIS. Requerido en todos los entornos.
DATABASE_URL=postgresql+asyncpg://motoya_user:TU_PASSWORD_DB@localhost:5432/motoya

# ── Redis ──────────────────────────────────────────────────────
# Usado para Celery (tareas en background) y caché.
REDIS_URL=redis://localhost:6379/0

# ── JWT ────────────────────────────────────────────────────────
# ⚠️ OBLIGATORIO cambiar en producción. Si APP_ENV=production y
# este valor no se cambia, el backend se rehusa a arrancar.
# Genera uno seguro con: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production
# Algoritmo de firma JWT. No cambiar a menos que sepas lo que haces.
JWT_ALGORITHM=HS256
# Duración del token en minutos. 1440 = 24 horas.
JWT_EXPIRATION_MINUTES=1440

# ── CORS ───────────────────────────────────────────────────────
# Orígenes permitidos separados por coma. Usar "*" solo en desarrollo.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Archivos / Uploads ─────────────────────────────────────────
# Directorio local para archivos subidos (se crea automáticamente).
UPLOAD_DIR=uploads
# Tamaño máximo de archivo en bytes. 10_485_760 = 10 MB.
MAX_UPLOAD_SIZE=10485760
# Tipos MIME permitidos para uploads, separados por coma.
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/webp,application/pdf
